# ── Database ──────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=altitude

# ── Server ────────────────────────────────────────────────────────────
PORT=5000

# ── Session secret (change this in production!) ───────────────────────
SESSION_SECRET=change_this_to_a_random_secret_string

# ── Frontend origin (for CORS) ────────────────────────────────────────
FRONTEND_URL=http://localhost:5173
